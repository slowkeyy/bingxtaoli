                            </div>
                            <span class="ml-2 text-xs text-slate-400">啟用</span>
                        </label>
                    </h3>
                    <div class="mt-2 flex-grow">
                        <input type="text" id="dc-webhook" placeholder="Webhook URL" class="w-full bg-slate-800 border border-slate-600 rounded px-2 py-2 text-white font-mono text-xs focus:outline-none focus:border-blue-500 mb-3">
                        <button onclick="fetchAllBingXData()" id="refresh-btn" class="bg-[#5865F2] hover:bg-[#4752C4] text-white px-4 py-2 rounded-lg font-medium transition-colors flex items-center justify-center gap-2 w-full shadow-lg">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg>
                            安全深度掃描
                        </button>
                        <div id="last-update" class="text-xs text-slate-500 text-center mt-2">等待更新...</div>
                    </div>
                </div>
            </div>
        </header>

        <div id="status-message" class="hidden mb-6 p-4 rounded-lg text-sm"></div>

        <!-- 數據表格區 -->
        <div class="glass-panel rounded-xl overflow-hidden shadow-2xl border border-slate-700">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[1000px]">
                    <thead>
                        <tr class="bg-slate-800/80 border-b border-slate-700 text-slate-300 text-xs md:text-sm uppercase tracking-wider">
                            <th class="p-4 font-semibold w-[15%]">交易對</th>
                            <th class="p-4 font-semibold text-right w-[15%]">結算倒數 / 費率</th>
                            <th class="p-4 font-semibold text-right w-[20%]">
                                吃單即時價差<br>
                                <span class="text-[10px] text-slate-500 normal-case">(合約 Bid - 現貨 Ask)</span>
                            </th>
                            <th class="p-4 font-semibold text-right w-[30%] bg-slate-800/50">
                                🛡️ 首檔流動性檢測 (USDT)<br>
                                <span class="text-[10px] text-slate-400 normal-case">判斷是否會產生嚴重滑點的關鍵</span>
                            </th>
                            <th class="p-4 font-semibold text-right w-[20%] bg-blue-900/20 border-l border-blue-800/50 text-blue-300">
                                實質總淨利 <br>
                                <span class="text-[10px] text-slate-400 normal-case">(費率 + 價差 - 成本)</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody id="data-body" class="divide-y divide-slate-800/50">
                        <tr><td colspan="5" class="p-8 text-center text-slate-500">點擊上方「安全深度掃描」開始擷取資料並分析流動性</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        // BingX 3 大核心 API
        const API_URLS = {
            premium: 'https://open-api.bingx.com/openApi/swap/v2/quote/premiumIndex',
            swapTicker: 'https://open-api.bingx.com/openApi/swap/v2/quote/ticker',
            spotTicker: 'https://open-api.bingx.com/openApi/spot/v1/ticker/bookTicker'
        };

        const getProxyUrl = (url) => `https://api.allorigins.win/raw?url=${encodeURIComponent(url)}`;

        let notifiedSymbols = {}; 

        window.onload = () => {
            // 載入設定，增加對新欄位的儲存
            const inputs = ['cost-input', 'time-limit-input', 'profit-threshold-input', 'cooldown-input', 'dc-webhook', 'min-volume-input'];
            inputs.forEach(id => {
                const saved = localStorage.getItem(id);
                if (saved !== null) document.getElementById(id).value = saved;
                document.getElementById(id).addEventListener('change', (e) => localStorage.setItem(id, e.target.value));
            });

            if(localStorage.getItem('dcEnable') === 'true') document.getElementById('dc-enable').checked = true;
            document.getElementById('dc-enable').addEventListener('change', (e) => localStorage.setItem('dcEnable', e.target.checked));

            setInterval(fetchAllBingXData, 60000);
            fetchAllBingXData();
        };

        async function fetchApiData(url, name) {
            try {
                const response = await fetch(url);
                if (!response.ok) throw new Error('Direct Fetch Failed');
                const json = await response.json();
                if (json.code === 0) return json.data;
                throw new Error('API Format Error');
            } catch (e) {
                console.log(`${name} 直連失敗，切換代理...`);
                const proxyRes = await fetch(getProxyUrl(url));
                if (!proxyRes.ok) throw new Error(`${name} Proxy Failed`);
                const text = await proxyRes.text();
                const json = JSON.parse(text);
                if (json.code === 0) return json.data;
                return [];
            }
        }

        async function fetchAllBingXData() {
            const refreshBtn = document.getElementById('refresh-btn');
            refreshBtn.classList.add('opacity-50', 'cursor-not-allowed');
            refreshBtn.innerHTML = '<svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg> 擷取與流動性分析中...';

            try {
                const [premiumData, swapTickerData, spotTickerData] = await Promise.all([
                    fetchApiData(API_URLS.premium, "PremiumIndex"),
                    fetchApiData(API_URLS.swapTicker, "SwapTicker"),
                    fetchApiData(API_URLS.spotTicker, "SpotTicker")
                ]);

                if (!premiumData.length || !swapTickerData.length || !spotTickerData.length) {
                    throw new Error("部分 API 數據回傳為空，請稍後重試");
                }

                processAndRenderData(premiumData, swapTickerData, spotTickerData);
                updateTimestamp();
            } catch (error) {
                console.error(error);
                showStatus(`掃描異常：${error.message}`, 'error');
            } finally {
                refreshBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                refreshBtn.innerHTML = '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg> 安全深度掃描';
            }
        }

        function processAndRenderData(premiumList, swapTickerList, spotTickerList) {
            const safeCost = parseFloat(document.getElementById('cost-input').value) / 100;
            const targetTimeLimitMinutes = parseInt(document.getElementById('time-limit-input').value);
            const profitThreshold = parseFloat(document.getElementById('profit-threshold-input').value) / 100;
            const cooldownMinutes = parseInt(document.getElementById('cooldown-input').value) || 0;
            const minVolumeThreshold = parseFloat(document.getElementById('min-volume-input').value) || 0;
            
            const isDcEnabled = document.getElementById('dc-enable').checked;
            const dcWebhookUrl = document.getElementById('dc-webhook').value;

            const tbody = document.getElementById('data-body');
            tbody.innerHTML = '';
            const now = new Date().getTime();
            let alertsToSend = [];

            // 建立快速查詢的 Map，同時提取價格與數量
            const swapMap = {};
            swapTickerList.forEach(item => { 
                // 合約看 Bid (買盤)。BingX 合約 API 欄位可能是 bidVol 或 bidVolume
                swapMap[item.symbol] = {
                    price: parseFloat(item.bidPrice),
                    qty: parseFloat(item.bidVolume || item.bidVol || item.bidQty || 0)
                }; 
            });

            const spotMap = {};
            spotTickerList.forEach(item => { 
                // 現貨看 Ask (賣盤)。BingX 現貨欄位通常是 askQty
                spotMap[item.symbol] = {
                    price: parseFloat(item.askPrice),
                    qty: parseFloat(item.askQty || item.askVolume || 0)
                }; 
            });

            const combinedData = [];

            premiumList.forEach(item => {
                const symbol = item.symbol;
                
                if (swapMap[symbol] && spotMap[symbol]) {
                    const fundingRate = parseFloat(item.lastFundingRate);
                    const timeDiff = parseInt(item.nextFundingTime) - now;
                    
                    const futuresBid = swapMap[symbol].price;
                    const spotAsk = spotMap[symbol].price;
                    
                    // 計算吃單當下的「真實價值深度 (USDT)」
                    const futuresBidValue = futuresBid * swapMap[symbol].qty;
                    const spotAskValue = spotAsk * spotMap[symbol].qty;
                    // 取兩邊最少的一邊作為瓶頸深度
                    const minLiquidityUsdt = Math.min(futuresBidValue, spotAskValue);
                    
                    const spreadRate = (futuresBid - spotAsk) / spotAsk; 
                    const netProfit = fundingRate + spreadRate - safeCost;

                    if (timeDiff > 0 && fundingRate > 0.0001) {
                        combinedData.push({
                            symbol: symbol,
                            fundingRate: fundingRate,
                            spreadRate: spreadRate,
                            netProfit: netProfit,
                            timeDiff: timeDiff,
                            futuresBid: futuresBid,
                            spotAsk: spotAsk,
                            futuresBidValue: futuresBidValue,
                            spotAskValue: spotAskValue,
                            minLiquidityUsdt: minLiquidityUsdt
                        });
                    }
                }
            });

            combinedData.sort((a, b) => b.netProfit - a.netProfit);

            combinedData.forEach(item => {
                const tr = document.createElement('tr');
                tr.className = "hover:bg-slate-800/50 transition-colors border-b border-slate-800";
                
                const timeDiffMinutes = Math.floor(item.timeDiff / 60000);
                const isProfitable = item.netProfit > 0;
                const isSpreadPositive = item.spreadRate > 0;
                
                // 護盾判定：雙邊最少深度必須大於設定值，才能算作真實機會
                const passLiquidityCheck = item.minLiquidityUsdt >= minVolumeThreshold;
                
                // 警報觸發條件：1. 倒數時間內 2. 實質總淨利達標 3. 通過深度測試
                const isTriggered = timeDiffMinutes <= targetTimeLimitMinutes && item.netProfit >= profitThreshold;

                if (isTriggered && passLiquidityCheck) {
                    tr.classList.add('bg-green-900/20'); // 安全機會給綠色底
                    
                    const lastNotified = notifiedSymbols[item.symbol] || 0;
                    if (now - lastNotified > cooldownMinutes * 60 * 1000) {
                        alertsToSend.push(item);
                        notifiedSymbols[item.symbol] = now; 
                    }
                } else if (isTriggered && !passLiquidityCheck) {
                    // 如果淨利高但深度不足，給紅色底並警示，且「絕對不會」傳到 Discord
                    tr.classList.add('bg-red-900/10'); 
                    tr.classList.add('opacity-70'); // 半透明化表示不可用
                }

                // UI 渲染：更精確的價格顯示
                const spreadText = `${isSpreadPositive ? '+' : ''}${(item.spreadRate * 100).toFixed(4)}%`;
                const spreadColor = isSpreadPositive ? 'text-green-400' : 'text-red-400';
                
                tr.innerHTML = `
                    <td class="p-4 font-bold text-white">${item.symbol.replace('-USDT', '')}</td>
                    <td class="p-4 text-right">
                        <div class="font-mono text-orange-300 text-sm">${formatCountdown(item.timeDiff)}</div>
                        <div class="font-mono text-blue-400 text-xs mt-1">+${(item.fundingRate * 100).toFixed(4)}%</div>
                    </td>
                    <td class="p-4 text-right">
                        <div class="font-mono ${spreadColor} font-semibold">${spreadText}</div>
                        <div class="text-[10px] text-slate-400 font-mono mt-1">
                            B: ${formatExactPrice(item.futuresBid)}<br>A: ${formatExactPrice(item.spotAsk)}
                        </div>
                    </td>
                    <td class="p-4 text-right bg-slate-800/30">
                        ${!passLiquidityCheck && isTriggered ? '<span class="text-[10px] bg-red-900 text-red-300 px-1 py-0.5 rounded mr-2 border border-red-700">⚠️ 深度不足攔截</span>' : ''}
                        <div class="font-mono text-sm ${passLiquidityCheck ? 'text-emerald-400' : 'text-red-400 font-bold'}">$${Math.floor(item.minLiquidityUsdt).toLocaleString()}</div>
                        <div class="text-[10px] text-slate-500 font-mono mt-1">
                            合約B: $${Math.floor(item.futuresBidValue).toLocaleString()} / 現貨A: $${Math.floor(item.spotAskValue).toLocaleString()}
                        </div>
                    </td>
                    <td class="p-4 text-right font-mono font-bold bg-blue-900/10 border-l border-blue-800/30 ${isProfitable && passLiquidityCheck ? 'text-green-400 glow-text-green' : 'text-slate-500'}">
                        ${isProfitable ? '+' : ''}${(item.netProfit * 100).toFixed(4)}%
                    </td>
                `;
                tbody.appendChild(tr);
            });

            if (combinedData.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="p-8 text-center text-slate-500">目前無符合條件之數據</td></tr>`;
            }

            if (isDcEnabled && dcWebhookUrl && alertsToSend.length > 0) {
                sendDiscordAlert(alertsToSend, dcWebhookUrl, safeCost);
            }
        }

        async function sendDiscordAlert(alerts, webhookUrl, currentSafeCost) {
            const chunkSize = 10;
            let successCount = 0;

            for (let i = 0; i < alerts.length; i += chunkSize) {
                const chunk = alerts.slice(i, i + chunkSize);
                const embeds = chunk.map(item => {
                    const fundRateStr = (item.fundingRate * 100).toFixed(4);
                    const spreadStr = (item.spreadRate * 100).toFixed(4);
                    const profitStr = (item.netProfit * 100).toFixed(4);
                    const costStr = (currentSafeCost * 100).toFixed(2);
                    const mins = Math.floor(item.timeDiff / 60000);
                    const spreadSign = item.spreadRate > 0 ? '+' : '';

                    return {
                        title: `🛡️ ${item.symbol} 安全雙開套利 (已過濾流動性)`,
                        color: 5763719, // 綠色系
                        fields: [
                            { name: "預測資金費率", value: `+${fundRateStr}%`, inline: true },
                            { name: "即時吃單價差", value: `${spreadSign}${spreadStr}%`, inline: true },
                            { name: `實質淨利 (扣${costStr}%)`, value: `**+${profitStr}%**`, inline: false },
                            { name: "首檔可吃流動性 (防護通過)", value: `🟢 最低保障: **$${Math.floor(item.minLiquidityUsdt).toLocaleString()}** USDT\n(合約Bid $${Math.floor(item.futuresBidValue)} / 現貨Ask $${Math.floor(item.spotAskValue)})`, inline: false },
                            { name: "精確報價", value: `合約Bid: \`${formatExactPrice(item.futuresBid)}\`\n現貨Ask: \`${formatExactPrice(item.spotAsk)}\``, inline: true },
                            { name: "結算倒數", value: `⏳ 剩 ${mins} 分鐘`, inline: true }
                        ],
                        footer: { text: "BingX 深度安全雷達 | Slippage Shield Active" },
                        timestamp: new Date().toISOString()
                    };
                });

                try {
                    const response = await fetch(webhookUrl, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            content: i === 0 ? "<@everyone> 🚨 **高利潤且具備安全深度**的機會浮現！請盡速評估。" : "",
                            embeds: embeds
                        })
                    });
                    
                    if (response.ok || response.status === 204) {
                        successCount += chunk.length;
                    } else throw new Error("發送失敗");
                } catch (error) {
                    console.error(error);
                    showStatus(`Discord 通知發送失敗: 請檢查 Webhook 網址。`, 'error');
                    return; 
                }
            }

            if (successCount > 0) {
                showStatus(`✅ 成功發送 ${successCount} 筆經過深度過濾的警報至 Discord`, 'success');
            }
        }

        function formatCountdown(ms) {
            if (ms <= 0) return "結算中";
            const s = Math.floor(ms / 1000);
            return `${Math.floor(s / 3600)}h ${Math.floor((s % 3600) / 60)}m ${s % 60}s`;
        }
        
        // 更精準的價格格式化：解決小數點被截斷造成的「利潤幽靈」現象
        function formatExactPrice(price) {
            if (price < 0.0001) return price.toFixed(8); // 極小幣種顯示 8 位
            if (price < 0.01) return price.toFixed(6);   // 小幣種顯示 6 位
            if (price < 1) return price.toFixed(5);      // 1 U 以下顯示 5 位
            return price.toFixed(4);                     // 正常幣種顯示 4 位
        }

        function updateTimestamp() {
            const lastUpdateEl = document.getElementById('last-update');
            if (lastUpdateEl) lastUpdateEl.innerText = `最後掃描: ${new Date().toLocaleTimeString()}`;
            
            setTimeout(() => { 
                const statusEl = document.getElementById('status-message');
                if (statusEl) statusEl.classList.add('hidden'); 
            }, 3000);
        }

        function showStatus(msg, type) {
            const el = document.getElementById('status-message');
            el.innerHTML = msg;
            el.className = `mb-6 p-4 rounded-lg text-sm ${type === 'error' ? 'bg-red-900/50 border border-red-700 text-red-200' : 'bg-green-900/50 border border-green-700 text-green-200'}`;
            el.classList.remove('hidden');
        }
    </script>
</body>
